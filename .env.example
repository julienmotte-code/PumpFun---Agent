# Core mode
PUMPFUN_MODE=paper
PUMPFUN_ENABLE_LIVE_TRADING=false

# Wallet
PUMPFUN_WALLET_PUBLIC_KEY=
PUMPFUN_PRIVATE_KEY=
PUMPFUN_WALLET_PRIVATE_KEY_ENV=PUMPFUN_PRIVATE_KEY

# Data / execution adapters
PUMPFUN_MARKETDATA_URL=
PUMPFUN_EXECUTOR_URL=

# RPC fallback probe
PUMPFUN_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
PUMPFUN_RPC_COMMITMENT=confirmed

# Runtime
PUMPFUN_DB_PATH=./data/pumpfun.sqlite
PUMPFUN_TOKEN_MINT=demo-mint
PUMPFUN_ITERATIONS=60
PUMPFUN_LOOP_DELAY_SECONDS=1

# Risk / sizing
PUMPFUN_TRADE_SIZE_USD=50
PUMPFUN_MAX_POSITION_USD=75
PUMPFUN_MAX_DAILY_LOSS_USD=150
PUMPFUN_MAX_OPEN_POSITIONS=3
